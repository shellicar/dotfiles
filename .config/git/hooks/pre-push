#!/bin/sh

# Gate the *remote* ref being pushed (the destination on the server), not the
# local branch name -- a local checkout can be called anything; what matters is
# what lands on the remote. Per ref, git feeds the hook on stdin:
#   <local ref> <local sha> <remote ref> <remote sha>

input=$(cat)

status=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "$remote_ref" ] && continue
  case "$remote_ref" in
    refs/heads/main|refs/heads/master) ;;
    refs/heads/docs/*|refs/heads/fix/*|refs/heads/security/*|refs/heads/feature/*|refs/heads/epic/*) ;;
    refs/heads/*)
      echo "Remote branch '${remote_ref#refs/heads/}' doesn't match allowed prefixes: docs/ fix/ security/ feature/ epic/" >&2
      echo "Push to an allowed branch name, or update the policy." >&2
      status=1 ;;
  esac
done <<EOF
$input
EOF
[ "$status" -eq 0 ] || exit 1

# Chain to a repo-local pre-push hook, re-feeding the same push input.
REPO_HOOK="$(git rev-parse --git-dir)/hooks/pre-push"
if [ -x "$REPO_HOOK" ]; then
  printf '%s\n' "$input" | "$REPO_HOOK" "$@"
  exit $?
fi
