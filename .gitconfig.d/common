[core]
	hooksPath = ~/.config/git/hooks
[alias]
	lfs-install = !git -c core.hooksPath=.git/hooks lfs install --local
	wt-create = "!f() { root=$(git rev-parse --show-toplevel) || exit 1; repo=$(basename \"$root\" | sed 's/--.*//'); leaf=$(printf '%s' \"$1\" | sed 's#^[^/]*/##' | tr '/' '-'); dest=\"$(dirname \"$root\")/$repo--$leaf\"; git fetch origin --quiet 1>&2 || exit 1; git worktree add --no-track -b \"$1\" \"$dest\" \"${2:-origin/main}\" 1>&2 || exit 1; if [ -f \"$dest/package.json\" ] && grep -q '\"packageManager\": *\"pnpm@' \"$dest/package.json\"; then (cd \"$dest\" && pnpm install --frozen-lockfile) 1>&2 || exit 1; fi; echo \"$dest\"; }; f"
[push]
	; harden --force-with-lease: also refuse unless the local ref included the remote-tracking tip you last saw, so a fetch right before the push can't silently refresh the lease and let you clobber
	useForceIfIncludes = true
	; don't auto-create/track a remote branch on push — set the upstream deliberately with `git push -u`
	autoSetupRemote = false
	; push to the branch's configured upstream and refuse if there is none (fresh branch needs `git push -u`); refuse if the upstream's name differs from the local branch
	default = simple
[branch]
	; adopt an upstream only when the new branch's name matches the remote branch's name — so cutting
	; a feature branch off origin/main does NOT make it track main (git's default 'true' does)
	autoSetupMerge = simple
