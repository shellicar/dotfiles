#!/usr/bin/env node
// tmux-snapshot — capture the current tmux server's layout to JSON and rehydrate
// it later. Per pane it records session/window/pane identity, the exact window
// layout, the cwd, the foreground command, a resolved process label, the claude
// session id (when applicable), and the five custom user-options the status bar
// renders from.
//
// Node, not shell: restore is plan-then-execute (compute every action first,
// then either print it as the default dry-run, or run it under --apply), which
// is far cleaner with real objects than with shell word-splitting — and
// sidesteps the IFS field-collapse traps entirely, since tmux args are passed
// as an array, never re-split.
//
// Process label: a pane's foreground is often a `node` wrapper (claude-sdk-cli
// launched via launcher.mjs), so the real CLI is a descendant. We scan the
// pane's tty (ps -t) rather than walk one level of children, which misses it.
//
// Every tmux read is pinned to an explicit pane/window id; nothing relies on the
// "current" pane, which follows focus.

'use strict';

const fs = require('fs');
const { execFileSync } = require('child_process');
const { parseArgs } = require('node:util');

const HOME = process.env.HOME;

// The snapshot file is named after the server's socket label, so each server
// round-trips to its own file and save/restore agree by label.
function snapshotPath(label) {
  return `${HOME}/.tmux-snapshot-${label}.json`;
}

// tmux keeps one socket per server in a per-uid directory; the socket filename
// is the server label. Single source of both the server list and each path.
function serverDir() {
  return `/tmp/tmux-${process.getuid()}`;
}

// The labels of the servers that currently exist: the sockets in serverDir().
// A missing directory (no server ever started) reads as none.
function listServers() {
  let names;
  try {
    names = fs.readdirSync(serverDir());
  } catch {
    return [];
  }
  return names.filter((n) => {
    try {
      return fs.statSync(`${serverDir()}/${n}`).isSocket();
    } catch {
      return false;
    }
  });
}

// The label of the server we're running inside, from $TMUX's socket path.
function currentLabel() {
  const socket = process.env.TMUX.split(',')[0]; // e.g. /tmp/tmux-501/shellicar
  return socket.slice(socket.lastIndexOf('/') + 1);
}
const SEP = '\x1f'; // US: a field separator that cannot appear in tmux values
const PARK = '999999'; // parking index for the throwaway window new-session spawns
const UUID = /[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}/g;
// The model as the CLI renders it in its status line: family, version, and a
// trailing '*' iff the model was overridden from the command line. We only
// record the model when that '*' is present (an override worth round-tripping).
const MODEL = /(Haiku|Sonnet|Fable|Opus) (\d+(?:\.\d+)?)(\*)?/g;

function die(msg) {
  process.stderr.write(`tmux-snapshot: ${msg}\n`);
  process.exit(1);
}

function note(msg) {
  process.stderr.write(`tmux-snapshot: ${msg}\n`);
}

function run(cmd, args, allowFail) {
  try {
    return execFileSync(cmd, args, { encoding: 'utf8' });
  } catch (e) {
    if (allowFail) return (e.stdout || '').toString();
    throw e;
  }
}

// A tmux caller bound to one server by label, so every command targets that
// named server rather than the ambient one $TMUX points at.
const serverTmux = (label) => (args, allowFail) => run('tmux', ['-L', label, ...args], allowFail);
const lines = (s) => (s || '').split('\n').filter(Boolean);

// Minimal ANSI, only when stdout is a terminal so piped/redirected output stays
// clean. Used to make the restore plan easier to scan at a glance.
const COLOUR = process.stdout.isTTY;
const paint = (code) => (s) => (COLOUR ? `\x1b[${code}m${s}\x1b[0m` : s);
const dim = paint('2');
const bold = paint('1');
const cyan = paint('36');

function requireTmux() {
  if (!process.env.TMUX) die('not inside a tmux server');
}

// The orphan trap: if this pane's server was orphaned — its socket removed and a
// fresh server started on the same label — then `-L <label>` reaches that other
// server, not the one we're inside, and a bare command would silently snapshot
// the wrong server. $TMUX's second field is our real server's pid; display-message
// reports the pid the socket resolves to now. A mismatch means we're the orphan.
// Only meaningful for a bare command (label from $TMUX); an explicit -L is a
// deliberate target, not "the server I'm in".
function assertNotOrphan(label, tmux) {
  const envPid = process.env.TMUX.split(',')[1];
  const livePid = (tmux(['display-message', '-p', '#{pid}'], true) || '').trim();
  if (livePid !== envPid) {
    die(`this pane belongs to an orphaned '${label}' server (pid ${envPid}); the '${label}' socket now points at ${livePid ? `pid ${livePid}` : 'nothing'}. Run from a live pane, or target it explicitly with -L.`);
  }
}

// Resolve the target as a { label, tmux } pair. -L names the server explicitly;
// otherwise it's the one we're inside (requires being inside one). Either way
// every command binds to the label with -L — tmux uses -L internally regardless,
// so normalising to it keeps one code path and pins the target exactly. For the
// bare case we also guard against the orphan trap before handing the target back.
function resolveTarget(values) {
  if (values.label !== undefined) return { label: values.label, tmux: serverTmux(values.label) };
  requireTmux();
  const label = currentLabel();
  const tmux = serverTmux(label);
  assertNotOrphan(label, tmux);
  return { label, tmux };
}

// --- save -------------------------------------------------------------------

function saveServer(label, tmux) {
  const file = snapshotPath(label);

  const fmt = [
    '#{pane_id}', '#{session_name}', '#{window_index}', '#{window_name}',
    '#{window_layout}', '#{pane_index}', '#{pane_tty}', '#{pane_current_path}',
    '#{pane_current_command}', '#{@title}', '#{@colour}', '#{@state}',
    '#{@role}', '#{@status}',
  ].join(SEP);

  // A stale socket (file present but server dead) makes list-panes fail hard.
  // allowFail turns that into empty output; a live server always reports at
  // least one pane, so empty means no server — skip cleanly, don't crash.
  const raw = tmux(['list-panes', '-a', '-F', fmt], true);
  if (!raw) {
    note(`no server running on '${label}', nothing to save`);
    return;
  }

  note(`saving server '${label}'`);
  const panes = lines(raw).map((line) => {
    const [
      paneId, session, windowIndex, windowName, windowLayout, paneIndex,
      paneTty, path, cmd, title, colour, state, role, status,
    ] = line.split(SEP);

    // If any process on the pane's tty is claude-sdk-cli, label it that.
    const shortTty = paneTty.replace(/^\/dev\//, '');
    const comm = run('ps', ['-t', shortTty, '-o', 'comm='], true);
    const proc = /claude-sdk-cli/.test(comm) ? 'claude-sdk-cli' : cmd;

    // Session id for claude panes: scrape the CLI's own status line, which
    // renders the id at the foot of the pane. The last UUID on screen is that
    // line; ids printed earlier in the transcript sit above it. A structural
    // source (a marker the CLI writes about its own pid/tty) would be sturdier;
    // deferred for now.
    let sessionId = '';
    let model = null;
    if (proc === 'claude-sdk-cli') {
      const screen = tmux(['capture-pane', '-p', '-t', paneId], true) || '';
      const found = screen.match(UUID);
      if (found) sessionId = found[found.length - 1];
      // Same bottom-most-line bet as the id: the last match on screen is the
      // status line. Only store it when overridden (group 3, the '*').
      const models = [...screen.matchAll(MODEL)];
      const last = models[models.length - 1];
      if (last && last[3]) model = { family: last[1], version: last[2] };
    }

    return {
      session, window_index: windowIndex, window_name: windowName,
      window_layout: windowLayout, pane_index: paneIndex, path, cmd, proc,
      session_id: sessionId,
      ...(model ? { model } : {}),
      options: {
        '@title': title, '@colour': colour, '@state': state,
        '@role': role, '@status': status,
      },
    };
  });

  const snapshot = {
    generated: new Date().toISOString(),
    socket: `${serverDir()}/${label}`,
    panes,
  };
  fs.writeFileSync(file, JSON.stringify(snapshot, null, 2) + '\n');
  process.stdout.write(summarize(panes) + '\n');
  note(`wrote ${panes.length} panes to ${file}`);
}

// save router: -a sweeps every server, -L names one, else the current server.
function cmdSave(values) {
  if (values.all) {
    if (values.label !== undefined) die('cannot combine -a with -L');
    const servers = listServers();
    if (!servers.length) die('no tmux servers found');
    for (const label of servers) saveServer(label, serverTmux(label));
    return;
  }
  const { label, tmux } = resolveTarget(values);
  saveServer(label, tmux);
}

// A readable tree of what was captured: session → window → panes, each pane
// showing its resolved process and cwd.
function summarize(panes) {
  const out = [];
  let lastSession = null;
  for (const w of groupWindows(panes)) {
    if (w.session !== lastSession) {
      out.push(w.session);
      lastSession = w.session;
    }
    const n = w.panes.length;
    out.push(`  ${w.window_index}  ${w.window_name}  (${n} pane${n > 1 ? 's' : ''})`);
    for (const p of w.panes) {
      const m = p.model ? `  (model: ${modelArg(p.model)})` : '';
      out.push(`       ${p.pane_index}  ${p.proc.padEnd(15)} ${p.path}${m}`);
    }
  }
  return out.join('\n');
}

// --- restore ----------------------------------------------------------------

// Group panes into windows (ordered by session, then numeric window index;
// panes within a window ordered by numeric pane index).
function groupWindows(panes) {
  const map = new Map();
  for (const p of panes) {
    const key = `${p.session}${SEP}${p.window_index}`;
    if (!map.has(key)) {
      map.set(key, {
        session: p.session, window_index: p.window_index,
        window_name: p.window_name, window_layout: p.window_layout, panes: [],
      });
    }
    map.get(key).panes.push(p);
  }
  const windows = [...map.values()];
  windows.sort((a, b) =>
    a.session < b.session ? -1 : a.session > b.session ? 1
      : Number(a.window_index) - Number(b.window_index));
  for (const w of windows) w.panes.sort((a, b) => Number(a.pane_index) - Number(b.pane_index));
  return windows;
}

// Work out, against the live server, exactly what restore would do. Returns a
// plan that both the default dry-run and an --apply run consume, so the preview
// can never diverge from what executes.
function planRestore(snapshot, tmux) {
  const windows = groupWindows(snapshot.panes);

  const liveSessions = new Set(lines(tmux(['list-sessions', '-F', '#{session_name}'], true)));
  const liveWindows = {};
  for (const s of liveSessions) {
    liveWindows[s] = new Set(lines(tmux(['list-windows', '-t', `=${s}`, '-F', '#{window_index}'], true)));
  }

  const wantedSessions = [...new Set(snapshot.panes.map((p) => p.session))];
  const createSessions = wantedSessions.filter((s) => !liveSessions.has(s));

  const createWindows = [];
  const skipWindows = [];
  for (const w of windows) {
    const exists = liveSessions.has(w.session) && liveWindows[w.session].has(String(w.window_index));
    (exists ? skipWindows : createWindows).push(w);
  }

  return { createSessions, createWindows, skipWindows };
}

// Reconstruct the CLI's model token from the saved components: the CLI parses
// `claude-<family>-<version>` and capitalises, so lowercase family and turn the
// version's dot into a dash (4.8 -> 4-8, 5 -> 5).
function modelArg(model) {
  return `claude-${model.family.toLowerCase()}-${model.version.replace('.', '-')}`;
}

function describePlan(plan) {
  const out = [];
  for (const s of plan.createSessions) out.push(`create session: ${s}`);
  for (const w of plan.createWindows) {
    const n = w.panes.length;
    out.push(`create window: ${bold(`${w.session}:${w.window_index}`)} "${w.window_name}" (${n} pane${n > 1 ? 's' : ''})`);
    for (const p of w.panes) {
      const exists = fs.existsSync(p.path);
      out.push(`    pane ${p.pane_index}: cwd=${p.path}${exists ? '' : dim(' (missing — opens in ~)')}`);
      if (p.proc === 'claude-sdk-cli' && p.session_id) {
        if (exists) {
          const model = p.model ? ` ${cyan(`--model ${modelArg(p.model)}`)}` : '';
          out.push(`      ${dim('run: claude-sdk-cli --resume')} ${bold(p.session_id)}${model}`);
        } else {
          out.push(`      ${dim('skip cli: dir missing')}`);
        }
      }
    }
  }
  for (const w of plan.skipWindows) out.push(dim(`skip window: ${w.session}:${w.window_index} (exists)`));
  return out;
}

function executePlan(plan, tmux) {
  // Create missing sessions detached; park the auto-spawned window so our
  // indexed windows are free, and reap it once the session has real windows
  // (killing it sooner could take the session with it and fire session-closed).
  const created = [];
  for (const s of plan.createSessions) {
    tmux(['new-session', '-d', '-s', s]);
    const ph = lines(tmux(['list-windows', '-t', `=${s}`, '-F', '#{window_id}']))[0];
    tmux(['move-window', '-s', ph, '-t', `${s}:${PARK}`]);
    created.push(s);
  }

  // Stage 1: build the structure. Create every window and pane, apply the saved
  // layout, set the window/pane labels. Panes are created regardless of whether
  // their saved cwd still exists (tmux falls back to HOME for a missing dir), so
  // the pane count matches the saved layout and the geometry fits exactly.
  for (const w of plan.createWindows) {
    const tgt = `${w.session}:${w.window_index}`;

    // First pane via new-window, the rest via split. Geometry is fixed from the
    // saved layout afterward, so the split direction is moot.
    w.panes.forEach((p, i) => {
      if (i === 0) tmux(['new-window', '-t', tgt, '-n', w.window_name, '-c', p.path]);
      else tmux(['split-window', '-t', tgt, '-c', p.path]);
    });
    tmux(['select-layout', '-t', tgt, w.window_layout]);

    // Window-scope labels (title/colour/state) — shared across the window's
    // panes, taken from the first.
    const o = w.panes[0].options;
    if (o['@title']) tmux(['set-option', '-w', '-t', tgt, '@title', o['@title']]);
    if (o['@colour']) tmux(['set-option', '-w', '-t', tgt, '@colour', o['@colour']]);
    if (o['@state']) tmux(['set-option', '-w', '-t', tgt, '@state', o['@state']]);

    for (const p of w.panes) {
      const pt = `${tgt}.${p.pane_index}`;
      // Pane-scope labels (role/status).
      if (p.options['@role']) tmux(['set-option', '-p', '-t', pt, '@role', p.options['@role']]);
      if (p.options['@status']) tmux(['set-option', '-p', '-t', pt, '@status', p.options['@status']]);
    }
  }

  // Stage 2: restore the CLIs, separately from the layout. Only launch --resume
  // when the pane's saved dir still exists — a missing dir would have landed the
  // pane in HOME, and spawning claude there is worse than leaving a plain shell.
  for (const w of plan.createWindows) {
    for (const p of w.panes) {
      if (p.proc !== 'claude-sdk-cli' || !p.session_id) continue;
      if (!fs.existsSync(p.path)) continue;
      const pt = `${w.session}:${w.window_index}.${p.pane_index}`;
      const model = p.model ? ` --model ${modelArg(p.model)}` : '';
      tmux(['send-keys', '-t', pt, '-l', `claude-sdk-cli --resume ${p.session_id}${model}`]);
      tmux(['send-keys', '-t', pt, 'Enter']);
    }
  }

  for (const s of created) tmux(['kill-window', '-t', `${s}:${PARK}`], true);
}

function cmdRestore(values) {
  if (values.all) die('-a is not supported for restore (single server only)');
  // Dry-run is the default: print the plan and change nothing. --apply commits.
  const apply = Boolean(values.apply);
  const { label, tmux } = resolveTarget(values);
  note(`restoring server '${label}'`);

  const file = snapshotPath(label);
  if (!fs.existsSync(file)) die(`no snapshot at ${file}`);
  const snapshot = JSON.parse(fs.readFileSync(file, 'utf8'));

  const plan = planRestore(snapshot, tmux);

  if (!apply) {
    process.stdout.write('DRY RUN — no changes will be made (pass --apply to commit)\n');
    const desc = describePlan(plan);
    if (desc.length) process.stdout.write(desc.join('\n') + '\n');
    note(`would create ${plan.createSessions.length} session(s), ${plan.createWindows.length} window(s); skip ${plan.skipWindows.length} existing`);
    return;
  }

  executePlan(plan, tmux);
  note(`restore complete from ${file} — created ${plan.createWindows.length} window(s), skipped ${plan.skipWindows.length}`);
}

// restore-server takes the label as a positional (`restore-server weaver`) and
// drives the same plan/execute path as `restore` — dry-run by default, --apply to
// commit. It exists to be run from *outside* the target server (the save → kill
// → restore cycle can't be driven from inside the server it's killing), where the
// -L flag reads as less obvious than a named label.
function cmdRestoreServer(values, label) {
  if (label === undefined) die('restore-server requires a label (e.g. restore-server weaver)');
  if (values.all) die('-a is not supported for restore-server (single server only)');
  cmdRestore({ ...values, label });
}

// --- dispatch ---------------------------------------------------------------

function usage() {
  process.stderr.write('usage: tmux-snapshot [-L label | -a] save\n');
  process.stderr.write('       tmux-snapshot [-L label] restore [--apply]\n');
  process.stderr.write('       tmux-snapshot restore-server <label> [--apply]\n');
  process.exit(2);
}

// parseArgs in strict mode: unknown flags throw and land on usage(). -L/-a and
// --apply are position-independent, so the subcommand may sit either side.
function main() {
  let parsed;
  try {
    parsed = parseArgs({
      allowPositionals: true,
      options: {
        label: { type: 'string', short: 'L' },
        all: { type: 'boolean', short: 'a' },
        apply: { type: 'boolean' },
      },
    });
  } catch (e) {
    note(e.message);
    usage();
  }

  const sub = parsed.positionals[0];
  if (sub === 'save') cmdSave(parsed.values);
  else if (sub === 'restore') cmdRestore(parsed.values);
  else if (sub === 'restore-server') cmdRestoreServer(parsed.values, parsed.positionals[1]);
  else usage();
}

main();
